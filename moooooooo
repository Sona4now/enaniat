  // ===== LEC 2 (21-40) =====
  {id:21, lec:'lec2', text:'رودولف توبفر هو المخترع السويسري لأولى القصص المصورة في أوائل القرن التاسع عشر.', answer:true, explain:'صحيح. رودولف توبفر فنان سويسري جمع الصور والنصوص لسرد القصص، وامتد تأثيره في أوروبا حتى الولايات المتحدة.'},
  {id:22, lec:'lec2', text:'صورة "رجل الدبابة" في ساحة تيانانمن 1989 تُعدّ مثالاً على عنصر الصدق البصري.', answer:false, explain:'خطأ. صورة رجل الدبابة تُعدّ مثالاً على عنصر "التوقيت" — التقطت اللحظة في توقيت مثالي جعلها أيقونة عالمية. أما مثال الصدق البصري فهو صورة آلان كردي 2015.'},
  {id:23, lec:'lec2', text:'القصص الرقمية التفاعلية تسمح للقارئ بالتفاعل مع المحتوى مثل تغيير تسلسل الأحداث.', answer:true, explain:'صحيح. من مميزات القصص الرقمية التفاعلية أنها تمنح القارئ إمكانية التنقل بين المشاهد وتغيير تسلسل الأحداث وحتى اتخاذ قرارات تؤثر على مسار القصة.'},
  {id:24, lec:'lec2', text:'الهدف الأساسي للصحافة التصويرية هو تجميل المحتوى النصي فقط.', answer:false, explain:'خطأ. الهدف الأساسي هو التقاط ونقل اللحظات والقصص المهمة بدقة ومصداقية، وإعلام الجمهور وإشراكه — وليس مجرد التجميل.'},
  {id:25, lec:'lec2', text:'أداة Shorthand تُستخدم لإنشاء قصص صحفية تفاعلية مع دمج الصور والفيديو والبيانات.', answer:true, explain:'صحيح. Shorthand أداة متخصصة لإنشاء قصص صحفية تفاعلية بسهولة مع إمكانية دمج عناصر الوسائط المتعددة المختلفة.'},
  {id:26, lec:'lec2', text:'القصص التفاعلية المباشرة (Real-time) لا تتحدث عن أحداث حية وإنما أحداث محفوظة.', answer:false, explain:'خطأ. القصص التفاعلية المباشرة تُغطي الأحداث الحية والعاجلة بتحديث مستمر بناءً على التفاعلات اللحظية مع الجمهور.'},
  {id:27, lec:'lec2', text:'StoryMapJS أداة تدمج الخرائط التفاعلية مع النصوص والصور لإخبار قصة جغرافية.', answer:true, explain:'صحيح. StoryMapJS مصمم خصيصاً لربط القصص بالمواقع الجغرافية عبر خرائط تفاعلية مع نصوص وصور.'},
  {id:28, lec:'lec2', text:'القصة الصحفية المصورة المصممة للتأثير العاطفي المفرط تحتفظ بقيمتها الصحفية.', answer:false, explain:'خطأ. الصور المصممة للتأثير العاطفي المفرط أو لإثارة جدل مفتعل تفقد قيمتها الصحفية وتتحول إلى دعاية أو تلاعب إعلامي.'},
  {id:29, lec:'lec2', text:'القصص التفاعلية متعددة المسارات (Branching paths) تسمح للقارئ بتحديد مسار القصة.', answer:true, explain:'صحيح. هذا النوع يمنح القارئ حرية الاختيار بين مسارات مختلفة للأحداث أو الشخصيات، مما يجعل تجربته فريدة ومختلفة عن غيره.'},
  {id:30, lec:'lec2', text:'الصدق البصري يعني أن الصورة يمكن تعديلها رقمياً طالما بدت واقعية.', answer:false, explain:'خطأ. الصدق البصري يعني عدم التجميل أو التحريف أو التلاعب الرقمي — الصورة تُقدم الحقيقة كما هي.'},
  {id:31, lec:'lec2', text:'Tableau أداة تحليل البيانات يمكن دمجها في القصص لعرض بيانات تفاعلية.', answer:true, explain:'صحيح. Tableau من أبرز أدوات البيانات التفاعلية وتُستخدم في الصحافة الرقمية لتقديم بيانات معقدة بصورة مرئية وتفاعلية.'},
  {id:32, lec:'lec2', text:'السرد البصري يعني أن الصورة تكتفي بعرض لقطة جامدة دون أبعاد أعمق.', answer:false, explain:'خطأ. السرد البصري يعني أن الصورة الجيدة تفتح باباً للتأمل وتُلمح لما وراء المشهد من سياق وأصوات ومشاعر.'},
  {id:33, lec:'lec2', text:'أهداف القصة الصحفية المصورة تشمل إعطاء الصوت لمن لا صوت لهم.', answer:true, explain:'صحيح. المصور الصحفي لا ينقل حدثاً فحسب، بل يمنح صوتاً للمهمشين والفئات التي لم تُمنح حق الكلام كاللاجئين وسكان الأحياء الفقيرة.'},
  {id:34, lec:'lec2', text:'تطورت القصص المصورة مع تقدم التكنولوجيا لتصبح رقمية وأكثر توافراً للجمهور العالمي.', answer:true, explain:'صحيح. أدى ظهور القصص المصورة الرقمية ووجودها على الإنترنت إلى توسيع نطاق وصولها ليشمل جمهوراً عالمياً واسعاً.'},
  {id:35, lec:'lec2', text:'القصة الإخبارية التفاعلية الموجهة (Guided) تمنح القارئ حرية كاملة في تحديد مسار القصة.', answer:false, explain:'خطأ. القصة الموجهة تأتي بمسار ثابت يجب على القارئ اتباعه، مع وجود بعض اللحظات التفاعلية المحدودة كالضغط على نقاط مضيئة.'},
  {id:36, lec:'lec2', text:'تعزيز التفاعل الرقمي أصبح هدفاً جديداً للقصة الصحفية المصورة في العصر الرقمي.', answer:true, explain:'صحيح. في العصر الرقمي أصبحت الصورة تفاعلية يمكن دمجها مع عناصر مرئية وروابط ورسوم متحركة لإثراء التجربة الصحفية.'},
  {id:37, lec:'lec2', text:'صورة آلان كردي عام 2015 كانت مثالاً على الصدق البصري لأنها قدمت الحقيقة دون تجميل.', answer:true, explain:'صحيح. الصورة لم تُجمّل الحدث ولم تُحرفه، بل قدمت الحقيقة كما هي وأثارت ضمير العالم، وهذا هو الصدق البصري بأعلى تجلياته.'},
  {id:38, lec:'lec2', text:'Adobe Animate يُستخدم لإنشاء محتوى تفاعلي ثابت فقط دون رسوم متحركة.', answer:false, explain:'خطأ. Adobe Animate مصمم أساساً لإنشاء رسوم متحركة ومحتوى تفاعلي بالحركة، وليس للمحتوى الثابت فقط.'},
  {id:39, lec:'lec2', text:'إمكانية التخصيص في القصص التفاعلية تتيح للمستخدم تجربة مخصصة حسب اهتماماته.', answer:true, explain:'صحيح. هذه الميزة من فوائد القصص الرقمية التفاعلية الأساسية — تجعل القصة أكثر تأثيراً لأن كل مستخدم يرى ما يهمه.'},
  {id:40, lec:'lec2', text:'الصحافة التصويرية تجمع بين العناصر البصرية والممارسات الصحفية لتقديم تصوير قوي للأحداث.', answer:true, explain:'صحيح. الصحافة التصويرية فرع صحفي متكامل يدمج قوة الصورة البصرية مع المهنية الصحفية في انتقاء اللحظات وتوثيق الأحداث والقضايا الإنسانية.'},

  // ===== LEC 3 (41-60) =====
  {id:41, lec:'lec3', text:'الأخبار العاجلة تُخبر القارئ بأحداث يعلم عنها مسبقاً بوقت طويل.', answer:false, explain:'خطأ. الأخبار العاجلة تنقل أحداثاً مهمة ذات قيمة إخبارية عالية تقع بشكل مفاجئ، وهي تقف على النقيض من الأخبار التقليدية.'},
  {id:42, lec:'lec3', text:'تويتر (X) نشأ عام 2006 كنظام لتبادل الرسائل القصيرة عبر الموبايل.', answer:true, explain:'صحيح. نشأ تويتر عام 2006 كنظام رسائل قصيرة وتطور ليصبح منصة رئيسية للأخبار العاجلة والتواصل الاجتماعي.'},
  {id:43, lec:'lec3', text:'الرسالة الإخبارية القصيرة SMS يجب ألا تزيد عن 10 كلمات وأفضل أقل من ذلك.', answer:true, explain:'صحيح. الرسالة القصيرة تتراوح بين 70-160 حرفاً ولا تزيد عن 10 كلمات، مع التركيز على تكثيف المعلومات في أقل عدد ممكن من الكلمات.'},
  {id:44, lec:'lec3', text:'الأخبار التي تتضمن تهديدات صحية لا تُعدّ ذات أولوية للإرسال عبر SMS.', answer:false, explain:'خطأ. الأخبار التي تحمل تهديداً صحياً لها أولوية قصوى في الإرسال عبر الرسائل القصيرة لأنها تتعلق مباشرة بسلامة القراء.'},
  {id:45, lec:'lec3', text:'التنويع في رسائل SMS يعني إرسال 3-5 رسائل يومياً تغطي اهتمامات مختلفة.', answer:true, explain:'صحيح. من المهم التنويع في عدد ومحتوى الرسائل بحيث تتوزع على فترات اليوم بشكل متوازن وتغطي اهتمامات متعددة.'},
  {id:46, lec:'lec3', text:'استخدام العامية في الرسائل الإخبارية القصيرة أمر مشجع لتقريب المحتوى من الجمهور.', answer:false, explain:'خطأ. على العكس، يجب الابتعاد عن العامية في SMS واستخدام فصحى سهلة بسيطة لأن الجمهور متنوع ثقافياً ومن مناطق مختلفة.'},
  {id:47, lec:'lec3', text:'الفيتشر الخبري مادة تفصيلية تستكشف الزوايا الإنسانية في القضايا والأحداث.', answer:true, explain:'صحيح. الفيتشر مادة غنية تُقدم الحقائق بصورة "مؤنسنة" من زاوية استثنائية تخلط الصراخ بالأمل بالتفكير كما يُقال عنه.'},
  {id:48, lec:'lec3', text:'الرسالة الإخبارية القصيرة يمكن استخدام المصطلحات الرياضية المعقدة فيها دون قيود.', answer:false, explain:'خطأ. من أبرز أخطاء SMS إساءة استخدام المصطلحات الرياضية، لذا يجب تفاديها وأن تكون المصطلحات واضحة الدلالة.'},
  {id:49, lec:'lec3', text:'وظيفة الاشتراك في خدمة الأخبار العاجلة تتضمن ثلاث طرق: تويتر والبريد الإلكتروني والهاتف المحمول.', answer:true, explain:'صحيح. أغلب وسائل الإعلام توفر هذه الطرق الثلاث للاشتراك في خدمات الأخبار العاجلة لضمان وصول الخبر العاجل للمتابعين.'},
  {id:50, lec:'lec3', text:'الفيتشر الخبري يقدم الحقائق بصورة جافة ومجردة مثل النشرات الإخبارية العادية.', answer:false, explain:'خطأ. الفيتشر يقدم الحقائق بصورة "مؤنسنة" (إنسانية) وليس جافة — ويعتمد على معالجة من زاوية استثنائية متفردة.'},
  {id:51, lec:'lec3', text:'من أبرز أنواع الفيتشر قصة الرأي التي تحلل الآراء حول قضايا جارية.', answer:true, explain:'صحيح. قصة الرأي (تحليل الآراء) واحدة من الأنواع الخمسة الأساسية للفيتشر إلى جانب قصة الشخص والقصة الإنسانية والخلفية والتجربة.'},
  {id:52, lec:'lec3', text:'اللغة المجازية في عنوان الفيتشر تُقلل من تفاعل القارئ مع المادة الصحفية.', answer:false, explain:'خطأ. اللغة المجازية في صياغة العناوين تؤدي إلى المزيد من التفاعل — فهي تُثير خيال القارئ وتدفعه للتعمق في القراءة.'},
  {id:53, lec:'lec3', text:'في SMS يجب تجنب ذكر ما هو معروف في أوصاف الأماكن مثل قول "أسيوط بصعيد مصر".', answer:true, explain:'صحيح. لضمان الاختصار نتجنب ذكر المعلومات المعروفة — نقول "مدبولي" مباشرة بدلاً من "رئيس الوزراء مصطفى مدبولي".'},
  {id:54, lec:'lec3', text:'البث المباشر للأحداث ألغى تماماً الحاجة إلى أدوار الصحفيين في استخلاص المعلومات.', answer:false, explain:'خطأ. رغم البث المباشر، لا تزال الحاجة قائمة لأدوار الصحفيين في استخلاص المعلومات المهمة وإيصالها للمتلقي الذي قد يفوته شيء أثناء المتابعة.'},
  {id:55, lec:'lec3', text:'التشويش الدلالي في الرسائل القصيرة يحدث عندما يفهم القارئ الرسالة بشكل مختلف عن المرسل.', answer:true, explain:'صحيح. التشويش الدلالي ناتج عن اختلاف دلالة الكلمات بين المرسل والمستقبل، أو اختلاف الفهم الضمني، أو الجمل شاذة التركيب.'},
  {id:56, lec:'lec3', text:'اقتباسات مباشرة في عنوان الفيتشر تُساعد على شخصنة الموضوع.', answer:true, explain:'صحيح. الاقتباس المباشر يجعل العنوان أكثر شخصية وقرباً من القارئ، مما يُحفزه على التعرف أكثر مع الموضوع.'},
  {id:57, lec:'lec3', text:'أخبار المغارم (كارتفاع الأسعار وزيادة الضرائب) لا تُعدّ ذات أولوية في خدمة SMS.', answer:false, explain:'خطأ. أخبار المغارم من الأخبار ذات الأولوية في SMS لأنها تُخبر الجمهور بأعباء إضافية ستُفرض عليهم وتؤثر مباشرة في حياتهم.'},
  {id:58, lec:'lec3', text:'وظيفة عنوان الفيتشر الخبري تشمل تسليط الضوء على الفكرة الرئيسية وجذب انتباه القارئ.', answer:true, explain:'صحيح. هاتان الوظيفتان الأساسيتان لعنوان الفيتشر — الجذب والتسليط، بالإضافة لإبراز النبرة الذاتية وكشف المفارقات.'},
  {id:59, lec:'lec3', text:'الدقة في الأرقام في SMS تعني ذكر أكبر عدد ممكن من الأرقام والنسب.', answer:false, explain:'خطأ. الدقة في الأرقام تعني الاختصار وعدم التضارب وتجنب إساءة تفسيرها، وأحياناً يكفي ذكر نسبة الفائز فقط دون الخاسر.'},
  {id:60, lec:'lec3', text:'الشخصنة في الرسائل القصيرة تُحقق اهتمام القارئ من خلال أسماء مشهورة وأماكن ذات قيمة نفسية.', answer:true, explain:'صحيح. الكلمات الشخصية (أسماء النجوم والأماكن الدينية والأندية الرياضية) تضع الرسالة في مربع الشخصنة وتستثير اهتمام القارئ.'},

  // ===== LEC 4 (61-80) =====
  {id:61, lec:'lec4', text:'محرر منصات التواصل الاجتماعي دوره يقتصر على إعادة نشر محتوى الصحيفة فقط.', answer:false, explain:'خطأ. للمحرر وظيفتان: إعادة إنتاج محتوى المنصات الأخرى، وصناعة محتوى خبري خاص بالمنصة من خلال متابعة التغريدات وإنتاج فيديوهات.'},
  {id:62, lec:'lec4', text:'محرر التواصل الاجتماعي يجب أن يكون أشد حدة وتوهجاً من المحرر التقليدي.', answer:true, explain:'صحيح. لأن منصات التواصل سريعة التطور وتتطلب حساسية خاصة للترندات واهتمامات الجمهور الرقمي، وهو ما يستلزم حدة أكبر في الإدراك.'},
  {id:63, lec:'lec3', text:'منصة تويتر (X) أنسب للأخبار المفصّلة الطويلة نظراً لمساحتها الكافية للكتابة.', answer:false, explain:'خطأ. تويتر مناسب للأخبار الموجزة والعاجلة. أما الأخبار المفصلة فتناسب منصة فيسبوك التي تتيح نشر عنوان وجزء من المقدمة مع رابط للتفاصيل.'},
  {id:64, lec:'lec4', text:'الأخبار التي تحمل قيمة المنافسة والصراع تُعدّ من الأخبار الجماهيرية الأكثر تداولاً.', answer:true, explain:'صحيح. أخبار المنافسات الرياضية والصراعات والجريمة والحرب من أكثر الأخبار جماهيرية على منصات التواصل الاجتماعي.'},
  {id:65, lec:'lec4', text:'قالب ألبوم الصور على التواصل الاجتماعي يُعدّ من أنواع الأخبار المفتوحة على الموقع.', answer:false, explain:'خطأ. ألبوم الصور من القوالب المغلقة على المنصات — المتابع يطالع المحتوى كاملاً دون الحاجة للعودة لموقع الصحيفة.'},
  {id:66, lec:'lec4', text:'الخوارزميات تُحلل ملفات المستخدمين واهتماماتهم لتحديد المحتوى الذي يُعرض لهم.', answer:true, explain:'صحيح. خوارزميات الذكاء الاصطناعي تُحلل السلوك الرقمي للمستخدمين وشبكة اهتماماتهم وتفضيلاتهم لتقديم محتوى مخصص لكل فرد.'},
  {id:67, lec:'lec4', text:'قالب الفيديو لا يُستخدم على منصة فيسبوك.', answer:false, explain:'خطأ. قالب الفيديو يُستخدم على جميع المنصات بما فيها فيسبوك وتويتر وإنستجرام، وهو من الأقوالب الأكثر انتشاراً نظراً لتحول المنصات نحو المحتوى المصور.'},
  {id:68, lec:'lec4', text:'الميتافيرس يجعل المتلقي جزءاً من الحدث الإخباري وليس مجرد متلقٍ سلبي.', answer:true, explain:'صحيح. تكنيك الميتافيرس يطور أساليب تقديم المحتوى ليصبح المتلقي عنصراً فاعلاً في التجربة الإخبارية من خلال تجارب غامرة.'},
  {id:69, lec:'lec4', text:'اختيار الأخبار الموافقة لترند المنصة يعني اختيار الأخبار التي تُغضب الجمهور.', answer:false, explain:'خطأ. اختيار الأخبار الموافقة للترند يعني اقتناص موضوع أو حدث بدأ يتداوله الناس بكثافة، بهدف البقاء داخل الترند أطول وقت ممكن.'},
  {id:70, lec:'lec4', text:'الخبر المغلق على الحساب يُعدّ من أفضل أنواع الأخبار على التواصل لأنه معدّ خصيصاً للمنصة.', answer:true, explain:'صحيح. الخبر المغلق يُعدّ خصيصاً بما يتناسب مع إمكانيات المنصة الفنية، مما يحقق أعلى درجات الاستخدام والانتشار.'},
  {id:71, lec:'lec4', text:'إنستجرام تناسبها الأخبار الثقيلة والمفصّلة أكثر من الفيديو والصور.', answer:false, explain:'خطأ. إنستجرام تناسبها الأخبار الخفيفة المتعلقة بالنجوم مع التركيز على الفيديو والصورة، وليس الأخبار المفصّلة التي تناسب فيسبوك.'},
  {id:72, lec:'lec4', text:'قالب المدونة على التواصل الاجتماعي يعتمد على تكثيف المعلومات في عدد محدود من الكلمات.', answer:true, explain:'صحيح. المدون الناجح يُجيد استخدام اللغة في أعلى قدراتها التعبيرية لنقل المعلومات بشكل مكثف ومؤثر.'},
  {id:73, lec:'lec4', text:'منصات التواصل الاجتماعي أصبحت بيئة صحفية مستقلة لها قواعدها في الاختيار والتحرير.', answer:true, explain:'صحيح. التواصل الاجتماعي تطور من مجرد قناة توزيع إلى بيئة صحفية كاملة بقواعد خاصة تختلف عن الإعلام التقليدي.'},
  {id:74, lec:'lec4', text:'أخبار ذوي الاحتياجات الخاصة والأطفال لا تحظى باهتمام على منصات التواصل.', answer:false, explain:'خطأ. هذه الأخبار من الفئة "ذات القيمة الإنسانية" وهي من أكثر الأخبار جماهيرية وتداولاً على منصات التواصل الاجتماعي.'},
  {id:75, lec:'lec4', text:'محرر التواصل يجب أن يتابع التغريدات والتدوينات على حسابات المسؤولين لصناعة أخبار منها.', answer:true, explain:'صحيح. من وظائف محرر التواصل صناعة الأخبار من خلال متابعة ما ينشره المسؤولون ونجوم المجتمع، وقد تكون هذه المنشورات أخباراً مهمة جداً.'},
  {id:76, lec:'lec4', text:'توزيع الأخبار على منصات التواصل يتجاهل الاعتبار الشخصي للمستخدم.', answer:false, explain:'خطأ. ذو القيمة الشخصية معيار أساسي في اختيار الأخبار — المستخدم عضو في مجموعات ذات اهتمامات مشتركة وتوجهات، ويفضل أخباراً تعكس هذه الاهتمامات.'},
  {id:77, lec:'lec4', text:'قالب الفيديو يتجاوز كونه مجرد تسجيل — ويعتمد على عنوان إشاري يُهيئ القارئ لمشاهدة الحدث.', answer:true, explain:'صحيح. صياغة قالب الفيديو تعتمد على وجود عنوان إشاري أو توضيحي يُترك بعده القارئ مع الفيديو ليعيش الحدث صوتاً وصورة.'},
  {id:78, lec:'lec4', text:'الميتافيرس تقنية لا علاقة لها بتطوير الصحافة أو تقديم المحتوى الإخباري.', answer:false, explain:'خطأ. الميتافيرس يُعدّ من أبرز تقنيات المستقبل في تطوير المحتوى الصحفي، ويُتيح تجارب غامرة تجعل المتلقي جزءاً من الحدث.'},
  {id:79, lec:'lec4', text:'محرر التواصل يختار الأخبار الأنسب لكل منصة لأن كل منصة لها طبيعة مختلفة.', answer:true, explain:'صحيح. كل منصة لها القوالب الأنسب لها — إنستجرام للصور والفيديو الخفيف، فيسبوك للتفاصيل، تويتر للموجز والعاجل.'},
  {id:80, lec:'lec4', text:'صحيفة تطبعها 20 ألف نسخة يومياً تصل لجمهور أكبر من متابعي حسابها على تويتر.', answer:false, explain:'خطأ. على العكس تماماً — بينما تطبع الصحيفة 20 ألف نسخة، يمتد متابعو حسابها على التواصل الاجتماعي إلى الملايين.'},

  // ===== LEC 5 (81-100) =====
  {id:81, lec:'lec5', text:'الموقع الإلكتروني يحتاج إلى ثلاثة عناصر أساسية: ملفات واستضافة واسم نطاق.', answer:true, explain:'صحيح. هذه العناصر الثلاثة ضرورية لأي موقع — الملفات تحتوي المحتوى، والاستضافة تحفظها، واسم النطاق يُعرّف عنوانه للمستخدمين.'},
  {id:82, lec:'lec5', text:'صفحة "من نحن" في الموقع تُعدّ أقل أهمية من الصفحة الرئيسية ويمكن الاستغناء عنها.', answer:false, explain:'خطأ. صفحة "من نحن" مهمة جداً لأنها تُعبر عن هوية المؤسسة وما تقدمه، وهي فرصة للمتلقي لفهم هوية المؤسسة وأهدافها.'},
  {id:83, lec:'lec5', text:'تحليل المنافسين والجمهور هو أولى خطوات تصميم موقع ويب.', answer:true, explain:'صحيح. التحليل هو الخطوة الأولى قبل البدء في أي تصميم — تحليل المحيط التجاري والمنافسين وجمهورك وتفضيلات الناس.'},
  {id:84, lec:'lec5', text:'الصفحة الرئيسية للموقع هي آخر ما يراه الزائر عند دخوله.', answer:false, explain:'خطأ. الصفحة الرئيسية هي أول ما يراه الزائر وواجهة الموقع — إما تجذبه ليستمر أو تُنفّره فيغادر دون عودة.'},
  {id:85, lec:'lec5', text:'شبكة الويب العالمية (WWW) تنشأ من تجميع جميع المواقع الإلكترونية معاً.', answer:true, explain:'صحيح. مجموع المواقع الإلكترونية في جميع البلدان يُؤدّي إلى وجود شبكة واسعة من المعلومات تعرف بشبكة الويب العالمية (WWW).'},
  {id:86, lec:'lec5', text:'قرابة 4.54 مليار شخص يستخدمون الإنترنت يومياً وهو ما يجعل الوجود الرقمي ضرورة قصوى.', answer:true, explain:'صحيح. هذا الرقم الهائل يعني أن التواجد على الإنترنت يُتيح الوصول لأكثر من نصف إجمالي سكان العالم.'},
  {id:87, lec:'lec5', text:'تحديد هدف الموقع وجمهوره المستهدف يمكن تأجيله لمرحلة التصميم الفعلي.', answer:false, explain:'خطأ. تحديد الأهداف يجب أن يسبق كل شيء — تحديد الأهداف الخاطئ سيجعل كل خطوات التصميم اللاحقة خاطئة وفاشلة.'},
  {id:88, lec:'lec5', text:'تحسين صفحة التواصل يتطلب عرض بيانات الاتصال بأسلوب جذاب يُحفز العميل على التواصل.', answer:true, explain:'صحيح. لا يكفي عرض البيانات بصورة عادية — يجب تحفيز العملاء للتواصل بأسلوب صريح وجذاب دون تردد أو تأخير.'},
  {id:89, lec:'lec5', text:'الموقع الإلكتروني الناجح لا يحتاج إلى خطوة التخطيط قبل البدء في التصميم.', answer:false, explain:'خطأ. التخطيط خطوة أساسية في مراحل التصميم — يشمل ترجمة التحليل والأهداف إلى مخطط تفصيلي وخريطة للموقع ومراحل تنفيذه.'},
  {id:90, lec:'lec5', text:'الاستجابة للمنصات المختلفة (Responsive Design) من الأسس المهمة لتحسين الصفحة الرئيسية.', answer:true, explain:'صحيح. Responsive Design يضمن أن يعمل الموقع بشكل صحيح على جميع الأجهزة من هواتف ذكية وأجهزة لوحية وحاسوب مكتبي.'},
  {id:91, lec:'lec5', text:'صفحة الخدمات يجب أن تُقدم وصفاً مطولاً ومعقداً لكل خدمة لإثبات الكفاءة.', answer:false, explain:'خطأ. صفحة الخدمات تحتاج لوصف بسيط مختصر يوضح لعملائك بسهولة ودون تعقيد كيف ستحل هذه الخدمات مشكلة ما.'},
  {id:92, lec:'lec5', text:'المواقع الإلكترونية يمكن أن تأخذ أشكالاً متعددة من المدونات الشخصية إلى مواقع التجارة الإلكترونية.', answer:true, explain:'صحيح. المواقع تتنوع من مدونات شخصية ومواقع شركات وحكوماتٍ ومواقع تواصل ومواقع إخبارية وتجارة إلكترونية ومواقع بحث.'},
  {id:93, lec:'lec5', text:'نص الصفحة الرئيسية لا يحتاج إلى دعوة للتفاعل (CTA) لأن المستخدم يعرف ماذا يفعل.', answer:false, explain:'خطأ. في كل مكان تلتقطه عين الزائر يجب وضع نص يدعوه للتفاعل مع المنتجات والخدمات — غياب CTA يؤدي لفقدان الزائر.'},
  {id:94, lec:'lec5', text:'الهدف الرئيسي للموقع الإلكتروني هو تكبيرك في عيون عملائك وجعلهم يثقون بخدماتك.', answer:true, explain:'صحيح. الموقع يهدف إلى إيجاد اندهاش لدى العملاء يجعلهم يريدون أن يكونوا جزءاً من خدماتك — ويُعظم صورة المؤسسة.'},
  {id:95, lec:'lec5', text:'المحتوى المكرر الذي يشبه ما رآه الزائر في مكان آخر يجذب انتباهه أكثر.', answer:false, explain:'خطأ. المحتوى المكرر يُحبطه الزائر ويعتبره محتوى مُغلقاً لا ينبغي الانتباه إليه — يجب أن يكون المحتوى فريداً ومميزاً.'},
  {id:96, lec:'lec5', text:'اسم النطاق (Domain Name) هو العنوان الذي يميز الموقع ويُمكّن المستخدمين من الوصول إليه.', answer:true, explain:'صحيح. اسم النطاق يُعرّف عنوان الموقع بشكل واضح وهو الهوية الرقمية التي يمكن للمستخدمين من خلالها إيجاد الموقع على الإنترنت.'},
  {id:97, lec:'lec5', text:'العوامل البصرية كالصور والرسوم الجرافيكية في الصفحة الرئيسية تُساعد الزائر على فهم الخدمات.', answer:true, explain:'صحيح. العوامل البصرية الجذابة تُلمع عين الزائر وتُساعده على فهم خدمات المؤسسة دون الحاجة لقراءة نص طويل.'},
  {id:98, lec:'lec5', text:'الاستضافة (Hosting) ليست ضرورية إذا كان الموقع صغيراً ومحدود المحتوى.', answer:false, explain:'خطأ. الاستضافة ضرورية لأي موقع بغض النظر عن حجمه — هي التي تحمي وتخزن ملفات الموقع وتجعله متاحاً على الإنترنت.'},
  {id:99, lec:'lec5', text:'خطوة التخطيط تشمل وضع خريطة للموقع ومخطط تفصيلي لمراحل التصميم.', answer:true, explain:'صحيح. خطوة التخطيط تترجم التحليل والأهداف إلى مخطط تفصيلي يشمل خريطة الموقع ومراحل التصميم وكيفية التنفيذ.'},
  {id:100, lec:'lec5', text:'نجاح الموقع الإلكتروني يعتمد فقط على التصميم الجمالي دون أهمية للمحتوى.', answer:false, explain:'خطأ. نجاح الموقع يعتمد على التكامل بين التصميم الجمالي والمحتوى القيّم وسهولة الاستخدام وتجربة المستخدم — والمحتوى يُعدّ الملك في الفضاء الرقمي.'}
];

function renderQuestions(filter) {
  const grid = document.getElementById('quiz-grid');
  const filtered = filter === 'all' ? questions : questions.filter(q => q.lec === filter);
  grid.innerHTML = filtered.map(q => `
    <div class="q-item ${q.answer ? 'q-true' : 'q-false'}" data-lec="${q.lec}">
      <div class="q-header" onclick="toggleAnswer(this)">
        <div class="q-num">${q.id}</div>
        <div class="q-text">${q.text}</div>
        <button class="q-toggle" aria-label="إظهار الإجابة">▼</button>
      </div>
      <div class="q-answer">
        <div class="verdict">${q.answer ? '✓ صحيح' : '✗ خطأ'}</div>
        <div class="explain">${q.explain}</div>
      </div>
    </div>
  `).join('');
}

function toggleAnswer(header) {
  const answer = header.nextElementSibling;
  const btn = header.querySelector('.q-toggle');
  answer.classList.toggle('show');
  btn.classList.toggle('open');
}

function filterQ(filter) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  renderQuestions(filter);
}

function showSection(id) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  window.scrollTo(0, 0);
}

// Init
renderQuestions('all');
document.getElementById('true-q').textContent = questions.filter(q => q.answer).length;
document.getElementById('false-q').textContent = questions.filter(q => !q.answer).length;
</script>
